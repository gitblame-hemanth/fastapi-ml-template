# =============================================================================
# FastAPI ML Service — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# All variables are prefixed with APP_ (see src/core/config.py).

# Application
APP_APP_NAME="FastAPI ML Service"
APP_APP_VERSION="1.0.0"
APP_DEBUG=false
APP_ENVIRONMENT=production

# Authentication (set API_KEY_ENABLED=true to require API key)
APP_API_KEY=
APP_API_KEY_ENABLED=false

# Redis (use redis://redis:6379 for docker-compose, redis://localhost:6379 for local)
APP_REDIS_URL=redis://redis:6379
APP_REDIS_CACHE_TTL=300

# Model
APP_MODEL_NAME=sklearn_classifier
APP_MODEL_PATH=

# Rate Limiting
APP_RATE_LIMIT_REQUESTS=100
APP_RATE_LIMIT_WINDOW=60

# Inference
APP_INFERENCE_TIMEOUT=30.0

# CORS (comma-separated origins)
APP_CORS_ORIGINS=["*"]

# Logging
APP_LOG_LEVEL=INFO
